{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recsys-lab.local/schema/reporting/benchmark_manifest.schema.json",
  "title": "Benchmark Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "kind",
    "generated_at_utc",
    "benchmark_id",
    "status",
    "benchmark_scope",
    "command",
    "cwd",
    "git",
    "runtime",
    "inputs",
    "artifacts"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "kind": {
      "const": "benchmark_manifest"
    },
    "generated_at_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{6}Z$"
    },
    "benchmark_id": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{6}Z_[a-z0-9_\\-]+$"
    },
    "status": {
      "enum": ["started", "completed", "failed", "cancelled"]
    },
    "benchmark_scope": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "cwd": {
      "type": "string",
      "minLength": 1
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit", "dirty"],
      "properties": {
        "commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{7,40}$"
        },
        "dirty": {
          "type": "boolean"
        },
        "branch": {
          "type": "string"
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["device_profile", "python_version", "dtype", "threading"],
      "properties": {
        "device_profile": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "python_version": {
          "type": "string"
        },
        "dtype": {
          "enum": ["float32", "float64"]
        },
        "threading": {
          "type": "object",
          "additionalProperties": false,
          "required": ["omp_num_threads", "blas_threads"],
          "properties": {
            "omp_num_threads": {
              "type": "integer",
              "minimum": 1
            },
            "blas_threads": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_ids"],
      "properties": {
        "run_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{6}Z_[a-z0-9_\\-]+$"
          }
        },
        "run_manifest_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "benchmark_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{6}Z_[a-z0-9_\\-]+$"
          }
        },
        "benchmark_manifest_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "model_seeds": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "started_at_utc": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{6}Z$"
        },
        "finished_at_utc": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{6}Z$"
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": {
          "type": "string"
        },
        "tables": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "figures": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stdout_log": {
          "type": "string"
        }
      }
    }
  }
}
